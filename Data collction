#include <stdio.h>
#include <time.h>
#include "jbd.h"
#include "mybmm.h"

int main() {
    char *device = "/dev/ttyACM0"; 
    jbd_session_t *jbd;  // Changed from jbd_context_t
    jbd_all_info_t info; // Changed from jbd_info_t
    
    // Initialize the BMS connection
    jbd = jbd_init(NULL, device, ""); 
    
    if (!jbd || jbd_open(jbd) != 0) {
        printf("Error: Could not connect to BMS on %s\n", device);
        return 1;
    }

    printf("Connected! Fetching data...\n");

    if (jbd_get_all_info(jbd, &info) == 0) {
        // Field names in this library are slightly different
        printf("Voltage: %.2fV\n", info.common.voltage);
        printf("Capacity: %d%%\n", info.common.percentage);
        printf("Temp 1: %.1fC\n", info.common.temps[0]);
    } else {
        printf("Error: Could not read data from BMS.\n");
    }

    jbd_close(jbd);
    return 0;
}


gcc -Wall -o my_bms my_bms.c jbd.o jbd_info.o serial.o utils.o list.o parson.o cfg.o -I. -I./include -lm
