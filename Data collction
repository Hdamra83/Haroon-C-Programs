#include <stdio.h>
#include <stdlib.h>
#include "jbd.h"

int main() {
    // This is the path to your USB adapter
    char *device = "/dev/ttyACM0"; 
    jbd_session_t *s;
    jbd_all_info_t info;

    printf("Opening JBD BMS on %s...\n", device);

    // 1. Initialize the session
    s = jbd_init(NULL, device, "");
    if (!s) {
        printf("Failed to initialize JBD session.\n");
        return 1;
    }

    // 2. Open the connection
    if (jbd_open(s) != 0) {
        printf("Error: Could not open connection. Check your USB cable and Sudo.\n");
        return 1;
    }

    // 3. Read the data
    if (jbd_get_all_info(s, &info) == 0) {
        printf("\n--- BMS DATA ---\n");
        printf("Voltage: %.2f V\n", info.common.voltage);
        printf("Capacity: %d %%\n", info.common.percentage);
        printf("Temp 1: %.1f C\n", info.common.temps[0]);
    } else {
        printf("Error: Failed to read data from BMS.\n");
    }

    // 4. Close
    jbd_close(s);
    return 0;
}


gcc -Wall -o my_bms my_bms.c jbd.o jbd_info.o serial.o utils.o list.o parson.o cfg.o -I. -I./include -lm
